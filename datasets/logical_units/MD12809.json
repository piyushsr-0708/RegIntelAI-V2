    {
      "logical_unit_id": "MD12809_lu37",
      "document_id": "MD12809",
      "title": "6.2.3 In the case of wrong reporting, representation for waiver shall not be considered.",
      "text": "6.2.3 In the case of wrong reporting, representation for waiver shall not be considered.\n(cf. para 2.1.2 above).",
