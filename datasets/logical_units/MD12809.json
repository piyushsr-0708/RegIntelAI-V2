    {
      "logical_unit_id": "MD12809_lu26",
      "document_id": "MD12809",
      "title": "3.2 Reporting of Diversions in CyM-CC Portal",
      "text": "3.2 Reporting of Diversions in CyM-CC Portal\nAll currency chest diversions (both between chests of the same bank and between chests",
