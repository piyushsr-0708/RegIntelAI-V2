    {
      "logical_unit_id": "MD12809_lu36",
      "document_id": "MD12809",
      "title": "6.2.2 Any penalty / penal interest waiver request shall be considered, only if the",
      "text": "6.2.2 Any penalty / penal interest waiver request shall be considered, only if the\napplication for the same is made in the CyM-CC portal within the prescribed timelines.\nWaiver request in any other mode shall not be considered.",
