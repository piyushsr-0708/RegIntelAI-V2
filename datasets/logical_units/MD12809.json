    {
      "logical_unit_id": "MD12809_lu29",
      "document_id": "MD12809",
      "title": "4. Rate of Penal Interest",
      "text": "4. Rate of Penal Interest\nPenal interest shall be levied at the rate of 2% over the prevailing Bank Rate for the period\nof delayed reporting for net withdrawal / wrong reporting / inclusion of ineligible amounts\nin chest balances.",
