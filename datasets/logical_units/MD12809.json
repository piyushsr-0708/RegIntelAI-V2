    },
    {
      "logical_unit_id": "MD12809_lu17",
      "document_id": "MD12809",
      "title": "2.1.2 Wrong Reporting",
      "text": "2.1.2 Wrong Reporting\nPenal interest shall be levied in respect of cases of wrong reporting in the same manner\ntill the date of receipt of corrected advice by Reserve Bank. As debits / credits to banks'\ncurrent accounts are raised on the basis of the transactions reported by the currency\nchests, penal interest shall invariably be levied in all cases of wrong reporting by the\ncurrency chests. It is expected that currency chests would ensure the correctness of\nfigures reported on the CyM-CC portal. Particular care shall be taken to ensure that\nremittances of fresh / re-issuable notes sent to the currency chests from RBI / Note\nPrinting Presses are not reported as 'deposit' transactions.",
      "node_type": "clause",
      "level": 5,
      "page_range": [
        3
      ],
      "hierarchy_node_ids": [
        "MD12809_n17"
      ],
      "block_ids": [
        "p3_b4",
