    {
      "logical_unit_id": "MD12963_lu11",
      "document_id": "MD12963",
      "title": "B. Applicability",
      "text": "B. Applicability\n3.\nThese Directions shall be applicable to all categories of Non-Banking Financial\nCompany (hereinafter collectively referred to as 'NBFCs' and individually as an\n'NBFC'), for all layers, unless specified otherwise.",
      "node_type": "subsection",
      "level": 4,
      "page_range": [
        2
      ],
