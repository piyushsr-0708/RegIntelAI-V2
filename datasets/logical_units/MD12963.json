    {
      "logical_unit_id": "MD12963_lu13",
      "document_id": "MD12963",
      "title": "D. Scope",
      "text": "D. Scope\n6.\nThe undernoted cases of amalgamation shall be covered under these Directions:\n(1) An NBFC with another NBFC.\n(2) An NBFC with any other entity not under the regulatory purview of RBI.\n(3) Any entity not under the regulatory purview of RBI with an NBFC.\n<image>",
      "node_type": "section",
      "level": 3,
