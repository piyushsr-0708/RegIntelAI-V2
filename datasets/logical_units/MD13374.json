    {
      "logical_unit_id": "MD13374_lu10",
      "document_id": "MD13374",
      "title": "(a) A customer desirous of opting for e-mandate facility shall undertake a one-time",
      "text": "(a) A customer desirous of opting for e-mandate facility shall undertake a one-time\nregistration process. The mandate shall be registered only after successful\nvalidation of additional factor of authentication (AFA), in addition to the normal\nprocess required by the issuer.",
      "node_type": "clause",
      "level": 5,
      "page_range": [
