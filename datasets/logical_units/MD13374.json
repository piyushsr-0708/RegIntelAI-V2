    {
      "logical_unit_id": "MD13374_lu12",
      "document_id": "MD13374",
      "title": "(c) The e-mandate may be for either a pre-specified fixed amount or for a variable",
      "text": "(c) The e-mandate may be for either a pre-specified fixed amount or for a variable\namount subject to the overall cap fixed by the RBI. In the case of variable e-\nmandates, the issuer shall provide the customer with a facility to specify the\nmaximum value of any recurring transaction.",
      "node_type": "clause",
      "level": 5,
      "page_range": [
        2
