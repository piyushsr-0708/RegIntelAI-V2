    {
      "logical_unit_id": "MD13374_lu11",
      "document_id": "MD13374",
      "title": "(b) Every e-mandate registered by the issuer shall specify the validity period of the",
      "text": "(b) Every e-mandate registered by the issuer shall specify the validity period of the\ne-mandate. The issuer shall provide the customer with a facility to modify the\nvalidity period or withdraw the e-mandate at any point of time. Information\nabout this facility shall be clearly communicated to the customer at the time of\nregistration.",
      "node_type": "clause",
      "level": 5,
      "page_range": [
        2
