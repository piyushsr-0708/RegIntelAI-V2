    {
      "logical_unit_id": "MD12648_lu16",
      "document_id": "MD12648",
      "title": "2.1.1 Delay in Reporting",
      "text": "2.1.1 Delay in Reporting\nIn the event of delay in reporting currency chest transactions, penal interest at the rate\nindicated in paragraph 4 of this circular shall be levied on the amount due from the chest\nholding bank for the period of delay. Penal interest shall be calculated on T+0 basis i.e.\npenal interest shall be levied in respect of transactions not reported by currency chests\nto the Issue Office on the same business day within the time limit prescribed above.",
      "node_type": "clause",
      "level": 5,
      "page_range": [
