    {
      "logical_unit_id": "MD12648_lu12",
      "document_id": "MD12648",
      "title": "1.2.2 Opening of Currency Chests on Sundays or Holidays - Reporting in CyM",
      "text": "1.2.2 Opening of Currency Chests on Sundays or Holidays - Reporting in CyM\nIn case CyM CC portal is available on the day a specific CC is permitted to operate (i.e.\non a local holiday), the CC shall report the transactions in CyM on the same day. In case\nCyM-CC portal is not available on the said day (i.e. on a global holiday / 2nd or 4th\nSaturdays of the month / Sunday), the CC shall report denomination-wise consolidated\ndeposit and/ or withdrawal amount and denomination-wise chest closing balance of the\nday by 7 pm to the concerned Issue Office of RBI by e-mail and report day's transactions\non CyM on the next working day.",
      "node_type": "clause",
      "level": 5,
      "page_range": [
        2
      ],
      "hierarchy_node_ids": [
