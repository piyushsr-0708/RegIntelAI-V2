    {
      "logical_unit_id": "MD12648_lu28",
      "document_id": "MD12648",
      "title": "3.3 Delayed reporting where currency chests had \"Net Deposit\"",
      "text": "3.3 Delayed reporting where currency chests had \"Net Deposit\"\nPenal interest at the prevailing rate for delayed reporting of the instances where the\ncurrency chest had reported \"net deposit\" shall not be charged. However, in order to\nensure proper discipline in reporting currency chest transactions, a flat penalty of\n₹50,000/- shall be levied on the currency chests for delayed reporting, irrespective of the\nvalue of net deposit.",
      "node_type": "subsection",
      "level": 4,
      "page_range": [
        5
