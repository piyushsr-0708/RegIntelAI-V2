    {
      "logical_unit_id": "MD12648_lu29",
      "document_id": "MD12648",
      "title": "4. Rate of Penal Interest",
      "text": "4. Rate of Penal Interest\nPenal interest shall be levied at the rate of 2% over the prevailing Bank Rate for the period\nof delayed reporting / wrong reporting / inclusion of ineligible amounts in chest balances.",
