    {
      "logical_unit_id": "MD12648_lu11",
      "document_id": "MD12648",
      "title": "1.2.1 The currency chests shall invariably report all transactions through CyM-CC portal",
      "text": "1.2.1 The currency chests shall invariably report all transactions through CyM-CC portal\non the same day by 7 pm.",
