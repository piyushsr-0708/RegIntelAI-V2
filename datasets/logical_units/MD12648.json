    {
      "logical_unit_id": "MD12648_lu33",
      "document_id": "MD12648",
      "title": "6.1 Competent Authority",
      "text": "6.1 Competent Authority\nThe Competent Authority to decide on the nature of irregularity and levy penalty\nthereof shall be the Officer-in-Charge of the Issue Department of the Regional Office\nunder whose jurisdiction the defaulting currency chest is located.",
      "node_type": "subsection",
      "level": 4,
      "page_range": [
        5
      ],
      "hierarchy_node_ids": [
        "MD12648_n33"
      ],
