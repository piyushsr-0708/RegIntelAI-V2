    {
      "logical_unit_id": "MD12648_lu27",
      "document_id": "MD12648",
      "title": "3.2 Reporting of Diversions in CyM-CC Portal",
      "text": "3.2 Reporting of Diversions in CyM-CC Portal\nAll currency chest diversions (both between chests of the same bank and between chests\nof different banks) have to be reported through 'Diversion Module' of CyM-CC Portal. The\nCC sending the diversion should initiate the entry. The receiving CC should acknowledge\nthe same. Diversions should not be reported as deposit / withdrawal. A penalty of\n₹50,000/- shall be levied for any such wrong reporting.",
      "node_type": "subsection",
      "level": 4,
      "page_range": [
        4
      ],
      "hierarchy_node_ids": [
        "MD12648_n27"
      ],
      "block_ids": [
