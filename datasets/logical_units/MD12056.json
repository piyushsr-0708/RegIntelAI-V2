    {
      "logical_unit_id": "MD12056_lu21",
      "document_id": "MD12056",
      "title": "2.1 Reporting of Soiled note remittances to RBI",
      "text": "2.1 Reporting of Soiled note remittances to RBI\nSoiled note remittances to RBI should not be shown as withdrawal by chest/s. In case\nsuch remittances to RBI are wrongly reported as 'withdrawals', a penalty of ₹ 50,000 will\nbe levied irrespective of the value of remittance and period of such wrong reporting.",
      "node_type": "subsection",
      "level": 4,
      "page_range": [
        4
