    {
      "logical_unit_id": "MD12056_lu25",
      "document_id": "MD12056",
      "title": "3. Rate of penal interest",
      "text": "3. Rate of penal interest\nPenal interest shall be levied at the rate of 2% over the prevailing Bank Rate for the\nperiod of delayed reporting/wrong reporting/non-reporting /inclusion of ineligible\namounts in chest balances.",
