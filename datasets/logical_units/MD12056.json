    {
      "logical_unit_id": "MD12056_lu17",
      "document_id": "MD12056",
      "title": "(i) Penal interest will be levied in all cases where the bank has enjoyed 'ineligible' credit",
      "text": "(i) Penal interest will be levied in all cases where the bank has enjoyed 'ineligible' credit\nin its current account with Reserve Bank on account of wrong reporting / delayed\nreporting / non-reporting of transactions. Penal measures will also be taken in cases of\nshortages in chest balances / remittances, shortages due to pilferage / frauds,\ncounterfeit banknotes detected in chest balances / remittances as per the prevailing\n\"Scheme of Penalties\".",
      "node_type": "clause",
      "level": 5,
      "page_range": [
        3
      ],
      "hierarchy_node_ids": [
        "MD12056_n17"
      ],
      "block_ids": [
