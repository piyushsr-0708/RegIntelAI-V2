    {
      "logical_unit_id": "MD12056_lu22",
      "document_id": "MD12056",
      "title": "2.2 Reporting of diversions in CyM - CC portal",
      "text": "2.2 Reporting of diversions in CyM - CC portal\nAll currency chest diversions (both between chests of the same bank and between\nchests of different banks) have to be reported through 'Diversion Module' of CyM-CC\nPortal. The CC sending the diversion should initiate the diversion entry. The receiving\nCC should acknowledge the same. Diversions must not be reported as\nDeposit/Withdrawal. A penalty of ₹ 50,000 will be levied for such wrong reporting.",
      "node_type": "subsection",
      "level": 4,
      "page_range": [
        4
