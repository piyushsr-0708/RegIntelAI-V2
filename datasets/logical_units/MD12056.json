    {
      "logical_unit_id": "MD12056_lu14",
      "document_id": "MD12056",
      "title": "1.3.1 Delay in Reporting -",
      "text": "1.3.1 Delay in Reporting -\nIn the event of delay in reporting currency chest transactions, penal interest at the rate\nindicated in paragraph 3 of this circular will be levied on the amount due from the chest\nholding bank for the period of delay. Penal interest will be calculated on T+0 basis i.e.\npenal interest will be levied in respect of transactions not reported by currency chests to\nthe Issue Office on the same business day within the time limit prescribed above.",
      "node_type": "clause",
      "level": 5,
      "page_range": [
        2
      ],
      "hierarchy_node_ids": [
        "MD12056_n14"
      ],
