    {
      "logical_unit_id": "MD12056_lu24",
      "document_id": "MD12056",
      "title": "2.3 Delayed reporting where currency chests had \"Net Deposit\"",
      "text": "2.3 Delayed reporting where currency chests had \"Net Deposit\"\nPenal interest at the prevailing rate for delayed reporting of the instances where the\ncurrency chest had reported \"net deposit\" may not be charged. However, in order to\nensure proper discipline in reporting currency chest transactions, a flat penalty of ₹\n50,000 may be levied on the currency chests for delayed reporting irrespective of the\nvalue of net deposit.",
      "node_type": "subsection",
      "level": 4,
      "page_range": [
