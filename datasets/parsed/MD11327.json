          }
        },
        {
          "block_id": "p1_b2",
          "type": "text",
          "bbox": [
            67.19999694824219,
            180.6549835205078,
            396.7980041503906,
            212.34725952148438
          ],
          "text": "1. The Chairman & Managing Director/Chief Executive Officer\n(All Banks having Currency Chests)",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
        },
        {
          "block_id": "p1_b3",
          "type": "text",
          "bbox": [
            67.20030212402344,
            226.37525939941406,
            220.47634887695312,
            258.0674133300781
          ],
          "text": "2. The Director of Treasuries\n(State Governments)",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
        },
        {
          "block_id": "p1_b4",
          "type": "text",
          "bbox": [
            67.55999755859375,
            270.85198974609375,
            168.63601684570312,
            292.8719787597656
          ],
          "text": "Madam / Dear Sir",
          "font_info": {
            "size": 12.0,
            "name": "Mangal",
            "flags": 4,
            "is_bold": false,
            "is_italic": false
          }
        },
        {
          "block_id": "p1_b5",
          "type": "text",
          "bbox": [
            67.55999755859375,
            306.02398681640625,
            543.458740234375,
            354.3119812011719
          ],
          "text": "Master Direction on Levy of Penal Interest for Delayed Reporting / Wrong \nReporting / Non-Reporting of Currency Chest Transactions and Inclusion of \nIneligible Amounts in Currency Chest Balances",
          "font_info": {
            "size": 12.0,
            "name": "Arial-BoldMT",
            "flags": 16,
            "is_bold": true,
            "is_italic": false
          }
        },
        {
          "block_id": "p1_b12",
          "type": "text",
          "bbox": [
            237.08990478515625,
            360.2225341796875,
            357.62628173828125,
            480.7589111328125
          ],
          "text": "Withdrawn",
          "font_info": {
            "size": 28.0,
            "name": "Arial",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
        },
        {
          "block_id": "p1_b6",
          "type": "text",
          "bbox": [
            67.55999755859375,
            367.7279968261719,
            543.4559936523438,
            447.1799621582031
          ],
          "text": "In terms of the Preamble, under Section 45 of the RBI Act, 1934 and 35 A of the Banking \nRegulation Act, 1949, the Bank issues guidelines / instructions for realising the \nobjectives of our Clean Note Policy.  With a view to sustain these efforts and ensure \ndiscipline among the banks on timely and accurate reporting of currency chest \ntransactions, we have issued instructions on the subject.",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
        },
        {
          "block_id": "p1_b7",
          "type": "text",
          "bbox": [
            67.55999755859375,
            467.8080139160156,
            540.2399291992188,
            515.4600219726562
          ],
          "text": "2. The Master Direction enclosed incorporates updated guidelines / circulars on the\nsubject. The Direction will be updated from time to time as and when fresh instructions\nare issued.",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
        },
        {
          "block_id": "p1_b8",
          "type": "text",
          "bbox": [
            67.55999755859375,
            534.9719848632812,
            468.57598876953125,
            556.9920043945312
          ],
          "text": "3. This Master Direction has been placed on RBI website at www.rbi.org.in.",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
        },
        {
          "block_id": "p1_b9",
          "type": "text",
          "bbox": [
            67.55999755859375,
            583.6079711914062,
            152.9759979248047,
            599.5800170898438
          ],
          "text": "Yours faithfully,",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
        },
        {
          "block_id": "p1_b10",
          "type": "text",
          "bbox": [
            67.55998229980469,
            630.16796875,
            205.65599060058594,
            661.97998046875
          ],
          "text": "(Manas Ranjan Mohanty) \nChief General Manager",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
        },
        {
          "block_id": "p1_b11",
          "type": "text",
          "bbox": [
            67.55999755859375,
            673.7279663085938,
            154.2960205078125,
            689.7000122070312
          ],
          "text": "Encl : As above",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
        }
