            90.66000366210938,
            90.11997985839844,
            320.0173034667969,
            106.4999771118164
          ],
          "text": "v. Violation of any of the terms of",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
        },
