            202.66798400878906,
            282.7572937011719,
            250.38003540039062
          ],
          "text": "The Chairman and Managing Director / \nChief Executive Officers, \nAll Banks",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
