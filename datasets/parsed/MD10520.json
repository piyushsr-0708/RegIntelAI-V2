            296.4840087890625,
            493.2359924316406,
            313.2120056152344
          ],
          "text": "Nature of Service \nParticulars of Incentives",
          "font_info": {
            "size": 12.0,
            "name": "Arial-BoldMT",
            "flags": 16,
            "is_bold": true,
            "is_italic": false
