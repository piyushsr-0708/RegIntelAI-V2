            266.1479797363281,
            172.7159881591797,
            282.1200256347656
          ],
          "text": "Madam / Dear Sir,",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
