            523.0562133789062,
            656.6520385742188
          ],
          "text": "b. \nAdjudication \nof \nmutilated \nnotes – ` 2 per piece",
          "font_info": {
            "size": 12.0,
            "name": "Arial-BoldMT",
            "flags": 16,
