            198.8279571533203,
            537.9395751953125,
            214.79995727539062
          ],
          "text": "iii. Banks may put in place a system of",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
