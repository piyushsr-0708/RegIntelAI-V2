          "type": "text",
          "bbox": [
            237.08990478515625,
            360.2225341796875,
            357.62628173828125,
            480.7589111328125
          ],
          "text": "Withdrawn",
          "font_info": {
            "size": 28.0,
            "name": "Arial",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
        },
        {
          "block_id": "p2_b11",
          "type": "text",
          "bbox": [
            337.5,
            476.0880126953125,
            537.9373779296875,
            555.5400390625
          ],
          "text": "50% of revenue expenditure for the \nfirst 3 years. In the North Eastern \nregion 50% of revenue expenditure \nwill be reimbursed for the first 5 \nyears.",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
        },
