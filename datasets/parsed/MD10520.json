          "bbox": [
            329.82000732421875,
            565.823974609375,
            523.057373046875,
            613.97998046875
          ],
          "text": "a. Exchange of soiled notes – ` 2 \nper packet for exchange of soiled \nnotes up to denomination ` 50",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
