          "type": "text",
          "bbox": [
            123.1199951171875,
            608.8200073242188,
            302.5584716796875,
            708.0
          ],
          "text": "agreement with RBI (for opening \nand maintaining currency chests) \nor deficiency in service in \nproviding exchange facilities, as \ndetected by RBI officials e.g. \n \na) Non-issue of coins over the",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
