          "type": "text",
          "bbox": [
            103.55999755859375,
            595.02001953125,
            291.9361267089844,
            611.4000244140625
          ],
          "text": "v. Violation of any of the  terms of",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
        },
        {
          "block_id": "p3_b6",
          "type": "text",
          "bbox": [
            304.0199890136719,
            595.02001953125,
            517.4798583984375,
            694.2000122070312
          ],
          "text": "₹ 10,000 for any violation of agreement \nor deficiency of service. \n \n₹ 5 lakh in case there are more than 5 \ninstances \nof \nviolation \nof \nagreement/deficiency in service by the \nbranch, during a financial year. The levy",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
            "is_italic": false
          }
        },
