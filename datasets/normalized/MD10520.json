            329.37603759765625,
            296.4120178222656
          ],
          "text": "3.2 Incentives for installation of machines",
          "font_info": {
            "size": 12.0,
            "name": "Arial-BoldMT",
            "flags": 16,
            "is_bold": true,
            "is_italic": false
