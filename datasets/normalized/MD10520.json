          "type": "text",
          "bbox": [
            118.68000030517578,
            487.2239990234375,
            297.9384460449219,
            551.2200317382812
          ],
          "text": "Note - ATMs distributing higher denominations of ` 500 and above are not eligible for this reimbursement",
          "font_info": {
            "size": 12.0,
            "name": "ArialMT",
            "flags": 0,
            "is_bold": false,
